{
  "name": "study-buddy",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "api": "json-server --watch mock/db.json --port 3001",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
